@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-5">
                <i class="bi bi-shield-lock text-danger" style="font-size: 4rem;"></i>
                <h2 class="fw-bold mt-3">Access Denied</h2>
                <p class="text-muted">You do not have the required Librarian permissions to view this page.</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-primary rounded-pill mt-3 px-4">
                    Return to Catalog
                </a>
            </div>
        </div>
    </div>
</div>