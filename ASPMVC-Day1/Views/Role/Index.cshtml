@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Manage Roles";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0">System Roles</h2>
            <p class="text-muted">Manage access levels and permissions.</p>
        </div>
        <a asp-action="AddRole" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Create New Role
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-bottom-0">Role ID</th>
                        <th class="px-4 py-3 border-bottom-0">Role Name</th>
                        <th class="px-4 py-3 border-bottom-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var role in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 text-muted small font-monospace">@role.Id</td>
                                <td class="px-4 py-3 fw-bold text-dark">
                                    @if (role.Name == "Librarian")
                                    {
                                        <span class="badge bg-danger rounded-pill me-2">Admin</span>
                                    }
                                    @role.Name
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill disabled">Edit</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                No roles found in the system.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>