@model EF_day3.Entities.Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="container w-50 bg-white p-5 rounded-4 shadow-sm mt-5 text-center">
    <h2 class="fw-bold mb-3 text-danger">Delete Book?</h2>
    <p class="text-muted mb-4">Are you sure you want to permanently delete <strong>@Model.Title</strong>? This action cannot be undone.</p>

    <div class="card bg-light border-0 p-3 mb-4 text-start mx-auto" style="max-width: 300px;">
        <div class="mb-2"><strong>ISBN:</strong> @Model.ISBN</div>
        <div class="mb-2"><strong>Year:</strong> @Model.PublishYear</div>
        <div><strong>Price:</strong> $@Model.Price</div>
    </div>

    <form action="/Book/Delete" method="post">
        <input type="hidden" name="Id" value="@Model.Id" />
        
        <div class="d-flex justify-content-center gap-3">
            <a href="/Book/Index" class="btn btn-light rounded-pill px-4 py-2 fw-bold">Cancel</a>
            <button type="submit" class="btn btn-danger rounded-pill px-4 py-2 fw-bold">Yes, Delete!</button>
        </div>
    </form>
</div>