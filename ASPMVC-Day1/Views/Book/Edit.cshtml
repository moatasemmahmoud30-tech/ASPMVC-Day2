@model ASPMVC_Day1.ViewModels.BookEditViewModel
@{
    ViewData["Title"] = "Edit Book";
}

<div class="container w-50 bg-white p-5 rounded-4 shadow-sm mt-5">
    <a asp-action="Index" class="text-decoration-none text-secondary mb-3 d-inline-block">&larr; Back</a>
    <h2 class="fw-bold mb-1">Edit Book</h2>
    <p class="text-muted mb-4">Update the details for "@Model.Title".</p>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger fw-bold bg-light p-2 rounded mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Version" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label text-muted fw-bold small"></label>
            <input asp-for="Title" class="form-control bg-light border-0 py-2" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="AuthorId" class="form-label text-muted fw-bold small">AUTHOR</label>
            <select asp-for="AuthorId" class="form-select bg-light border-0 py-2" asp-items="@(new SelectList(ViewBag.Authors, "Id", "Name"))">
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="ISBN" class="form-label text-muted fw-bold small"></label>
            <input asp-for="ISBN" class="form-control bg-light border-0 py-2" />
        </div>

        <div class="mb-3">
            <label asp-for="CategoryId" class="form-label text-muted fw-bold small">CATEGORY</label>
            <select asp-for="CategoryId" class="form-select bg-light border-0 py-2" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="PublishYear" class="form-label text-muted fw-bold small">PUBLISH YEAR</label>
            <input asp-for="PublishYear" class="form-control bg-light border-0 py-2" />
        </div>

        <div class="mb-4">
            <label asp-for="Price" class="form-label text-muted fw-bold small"></label>
            <input asp-for="Price" class="form-control bg-light border-0 py-2" />
        </div>

        @if (Model.ExistingAttachments.Any())
        {
            <div class="mb-4 bg-light p-3 rounded">
                <p class="text-muted fw-bold small mb-3">CURRENT ATTACHMENTS</p>
                <div class="row g-3">
                    @foreach (var attachment in Model.ExistingAttachments)
                    {
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm position-relative">
                                <img src="@attachment.FilePath" class="card-img-top" style="height: 120px; object-fit: cover;" alt="Attachment" />
                                
                                <button type="submit"
                                        asp-action="DeleteAttachment"
                                        asp-route-attachmentId="@attachment.Id"
                                        asp-route-bookId="@Model.Id"
                                        formnovalidate
                                        class="btn btn-sm btn-danger rounded-circle shadow position-absolute top-0 end-0 m-1"
                                        onclick="return confirm('Delete this image permanently?');">
                                    &times;
                                </button>
                                
                                <div class="card-footer bg-white border-0 py-1 px-2 text-truncate small text-muted">
                                    @attachment.FileName
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="mb-4">
            <label asp-for="NewFiles" class="form-label text-muted fw-bold small">ADD MORE ATTACHMENTS (Optional)</label>
            <input asp-for="NewFiles" type="file" multiple class="form-control bg-light border-0 py-2" />
        </div>

        <div class="mb-4">
            <label asp-for="NewFiles" class="form-label text-muted fw-bold small">REPLACE ATTACHMENTS (Optional)</label>
            <input asp-for="NewFiles" type="file" multiple class="form-control bg-light border-0 py-2" />
            <small class="text-muted">Uploading new files will delete the current attachments.</small>
        </div>

        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold">Update Book</button>
    </form>
</div>