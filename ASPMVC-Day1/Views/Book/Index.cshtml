@model IEnumerable<ASPMVC_Day1.ViewModels.BookCardViewModel>
@{
    ViewData["Title"] = "Books";
}

<div class="container mt-4">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-secondary mb-3 d-inline-block">&larr; Back</a>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Books</h2>
            <p class="text-muted">Manage and audit your books catalog.</p>
        </div>
        <a asp-controller="Book" asp-action="Add" class="btn btn-primary rounded-pill px-4">+ Add Book</a>
    </div>

    <form method="get" asp-action="Index" class="d-flex mb-4 gap-3 align-items-center">
        <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-pill flex-grow-1" placeholder="Search books...">
        
        <select name="categoryId" class="form-select rounded-pill w-auto" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    if (ViewBag.CategoryId != null && (int)ViewBag.CategoryId == cat.Id)
                    {
                        <option value="@cat.Id" selected>@cat.Name</option>
                    }
                    else
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            }
        </select>

        <input type="number" step="0.01" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control rounded-pill w-auto" placeholder="Max Price ($)" style="max-width: 150px;">

        <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">Filter</button>
    </form>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 mb-5">
        @foreach (var item in Model)
        {
            <div class="col">
                <partial name="_BookCardPartial" model="item" />
            </div>
        }
    </div>

    @{
        int currentPage = ViewBag.CurrentPage ?? 1;
        int prevPage = currentPage - 1;
        int nextPage = currentPage + 1;
    }

    <nav aria-label="Book pagination" class="d-flex justify-content-center mt-4">
        <ul class="pagination shadow-sm rounded-pill">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link rounded-start-pill border-0 text-muted" 
                   asp-action="Index" 
                   asp-route-pageNumber="@prevPage" 
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-categoryId="@ViewBag.CategoryId"
                   asp-route-maxPrice="@ViewBag.MaxPrice">
                   &larr; Previous
                </a>
            </li>
            <li class="page-item active">
                <span class="page-link border-0 bg-primary">@currentPage</span>
            </li>
            <li class="page-item">
                <a class="page-link rounded-end-pill border-0 text-dark" 
                   asp-action="Index" 
                   asp-route-pageNumber="@nextPage" 
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-categoryId="@ViewBag.CategoryId"
                   asp-route-maxPrice="@ViewBag.MaxPrice">
                   Next &rarr;
                </a>
            </li>
        </ul>
    </nav>
</div>