@model IEnumerable<EF_day3.Entities.Book>
@{
    ViewData["Title"] = "Books";
}

<div class="container mt-4">
    <a href="/" class="text-decoration-none text-secondary mb-3 d-inline-block">&larr; Back</a>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Books</h2>
            <p class="text-muted">Manage and audit your books catalog.</p>
        </div>
        <a href="/Book/Add" class="btn btn-primary rounded-pill px-4">+ Add Book</a>
    </div>

    <div class="d-flex mb-3 gap-3">
        <input type="text" class="form-control rounded-pill w-50" placeholder="Search books...">
        
        <select class="form-select rounded-pill w-auto">
            @foreach (var cat in ViewBag.Categories)
            {
                <option>@cat</option>
            }
        </select>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>TITLE</th>
                    <th>AUTHOR</th>
                    <th>ISBN</th>
                    <th>CATEGORY</th>
                    <th>Year</th>
                    <th>Price</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.Title</td>
                        <td class="align-middle">@item.Author.Name</td>
                        <td class="align-middle">@item.ISBN</td>
                        <td class="align-middle">@item.Category.Name</td>
                        <td class="align-middle">@item.PublishYear</td>
                
                        <td class="fw-bold text-success">$@item.Price</td>
                
                        <td class="text-end">
                        <td class="align-middle">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light border-0" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots"></i>
                                </button>
    
                                <ul class="dropdown-menu shadow">
                                    <li>
                                        <a href="/Book/Details/@item.Id" class="dropdown-item text-info fw-bold">Details</a>
                                    </li>
                                    <li>
                                        <a href="/Book/Edit/@item.Id" class="dropdown-item text-warning fw-bold">Edit</a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a href="/Book/Delete/@item.Id" class="dropdown-item text-danger fw-bold">Delete</a>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>