@model IEnumerable<ASPMVC_Day1.ViewModels.BookCardViewModel>
@{
    ViewData["Title"] = "Books";
}

<div class="container mt-4">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-secondary mb-3 d-inline-block">&larr; Back</a>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Books</h2>
            <p class="text-muted">Manage and audit your books catalog.</p>
        </div>
        <a asp-controller="Book" asp-action="Add" class="btn btn-primary rounded-pill px-4">+ Add Book</a>
    </div>

    <div class="d-flex mb-4 gap-3">
        <input type="text" class="form-control rounded-pill w-50" placeholder="Search books...">
        
        <select class="form-select rounded-pill w-auto">
            <option value="">All Categories</option>
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 mb-5">
        @foreach (var item in Model)
        {
            <div class="col">
                <partial name="_BookCardPartial" model="item" />
            </div>
        }
    </div>
</div>